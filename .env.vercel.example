# Produccion en Vercel: usa una URL publica del backend.
# Opcion recomendada si el backend esta en Railway:
VITE_API_URL=https://TU-BACKEND.up.railway.app/api

# Opcion temporal si quieres probar Vercel contra tu backend local:
# 1. Ejecuta Laravel local en http://localhost:8000
# 2. Expone ese puerto con ngrok/cloudflared
# 3. Coloca la URL HTTPS del tunel, por ejemplo:
# VITE_API_URL=https://TU-TUNEL.ngrok-free.app/api

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_STRIPE_PUBLIC_KEY=
