# Desarrollo local:
VITE_API_URL=http://localhost:8000/api

# En Vercel no uses localhost salvo que abras la app desde la misma PC
# donde corre Laravel. Para produccion usa:
# VITE_API_URL=https://TU-BACKEND.up.railway.app/api
# o una URL HTTPS de ngrok/cloudflared si el backend sigue local.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_STRIPE_PUBLIC_KEY=

# Cloudinary no se configura en el frontend.
# Las credenciales privadas van en backend_cup/.env porque Laravel sube los archivos a Cloudinary.
